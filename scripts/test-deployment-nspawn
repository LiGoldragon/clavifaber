#!/usr/bin/env bash
#
# test-deployment-nspawn — exercise clavifaber's deployment shape inside
# a systemd-nspawn container.
#
# What the test does:
#   1. Builds the clavifaber binary via nix.
#   2. Spins up a tiny rootfs (just enough for nspawn — /etc/os-release,
#      empty system dirs).
#   3. Bind-mounts /nix/store read-only so the clavifaber closure is
#      reachable inside the container.
#   4. Bind-mounts a host-visible state directory at /var/lib/clavifaber.
#   5. Runs the same sequence of NOTA-only clavifaber calls that
#      CriomOS's complex-init systemd unit runs at boot.
#   6. Verifies the expected files exist on the host (via the bind),
#      with the expected mode bits and content.
#
# Requires:
#   - systemd-nspawn (privileged; sudo will prompt unless your sudoers
#     allows passwordless `systemd-nspawn`)
#   - nix
#
# Usage:
#   nix run .#test-deployment-nspawn
#   # or directly:
#   bash scripts/test-deployment-nspawn

set -euo pipefail

if ! command -v systemd-nspawn >/dev/null; then
  echo "FAIL: systemd-nspawn not on PATH" >&2
  exit 1
fi

if ! command -v nix >/dev/null; then
  echo "FAIL: nix not on PATH" >&2
  exit 1
fi

if [[ "${1:-}" == "" ]]; then
  CLAVIFABER_BIN_PATH=$(nix build --print-out-paths --no-link .# 2>/dev/null)/bin/clavifaber
else
  CLAVIFABER_BIN_PATH="$1"
fi

if [[ ! -x "$CLAVIFABER_BIN_PATH" ]]; then
  echo "FAIL: clavifaber binary not executable at $CLAVIFABER_BIN_PATH" >&2
  exit 1
fi

TEST_ROOT=$(mktemp -d /tmp/clavifaber-nspawn.XXXXXX)
ROOTFS="$TEST_ROOT/root"
STATE_DIR="$TEST_ROOT/state"
MACHINE_NAME="clavifaber-test-$$"

cleanup() {
  # Best-effort: terminate any lingering machine, then rm the test root.
  machinectl terminate "$MACHINE_NAME" 2>/dev/null || true
  rm -rf "$TEST_ROOT"
}
trap cleanup EXIT

# Minimum rootfs systemd-nspawn accepts.
mkdir -p "$ROOTFS"/{etc,bin,proc,sys,dev,tmp,run,usr,var,sbin}
echo 'NAME="ClaviFaberDeploymentTest"' > "$ROOTFS/etc/os-release"

# Host-visible state dir; nspawn binds this at /var/lib/clavifaber.
mkdir -p "$STATE_DIR"
chmod 755 "$STATE_DIR"

echo "=== clavifaber deployment test (systemd-nspawn) ==="
echo "    rootfs:        $ROOTFS"
echo "    state dir:     $STATE_DIR"
echo "    machine name:  $MACHINE_NAME"
echo "    clavifaber:    $CLAVIFABER_BIN_PATH"

# The sequence inside the container mirrors CriomOS's complex-init unit:
#   clavifaber '(IdentitySetup ...)'
#   clavifaber '(PublicKeyPublicationWriting ...)'
INSIDE_CONTAINER_SCRIPT=$(cat <<EOF
set -e
echo "[in container] uname: \$(uname -a)"
echo "[in container] step 1/2: IdentitySetup"
"$CLAVIFABER_BIN_PATH" '(IdentitySetup "/var/lib/clavifaber")'
echo "[in container] step 2/2: PublicKeyPublicationWriting"
"$CLAVIFABER_BIN_PATH" '(PublicKeyPublicationWriting nspawn-host "/var/lib/clavifaber" None None "/var/lib/clavifaber/publication.nota")'
echo "[in container] sequence done"
EOF
)

echo ""
echo "--- launching nspawn (sudo required) ---"
sudo systemd-nspawn \
  --directory="$ROOTFS" \
  --bind-ro=/nix/store \
  --bind="$STATE_DIR:/var/lib/clavifaber" \
  --machine="$MACHINE_NAME" \
  --resolv-conf=off \
  --as-pid2 \
  --quiet \
  -- /bin/sh -c "$INSIDE_CONTAINER_SCRIPT"

echo ""
echo "--- verifying host-visible outputs ---"

KEY="$STATE_DIR/key.pem"
PUB="$STATE_DIR/ssh.pub"
PUBLICATION="$STATE_DIR/publication.nota"

for required in "$KEY" "$PUB" "$PUBLICATION"; do
  if [ ! -s "$required" ]; then
    echo "FAIL: $required missing or empty"
    exit 1
  fi
done

KEY_MODE=$(stat -c %a "$KEY")
PUB_MODE=$(stat -c %a "$PUB")
PUBLICATION_MODE=$(stat -c %a "$PUBLICATION")

if [ "$KEY_MODE" != "600" ]; then
  echo "FAIL: key.pem mode $KEY_MODE (expected 600)"
  exit 1
fi
if [ "$PUB_MODE" != "644" ]; then
  echo "FAIL: ssh.pub mode $PUB_MODE (expected 644)"
  exit 1
fi
if [ "$PUBLICATION_MODE" != "644" ]; then
  echo "FAIL: publication.nota mode $PUBLICATION_MODE (expected 644)"
  exit 1
fi

if ! grep -q 'BEGIN PRIVATE KEY' "$KEY"; then
  echo "FAIL: key.pem missing PEM header"
  exit 1
fi
if ! head -c 12 "$PUB" | grep -q '^ssh-ed25519'; then
  echo "FAIL: ssh.pub does not start with ssh-ed25519"
  exit 1
fi
if ! grep -q 'PublicKeyPublication' "$PUBLICATION"; then
  echo "FAIL: publication.nota missing PublicKeyPublication record"
  exit 1
fi
if ! grep -q 'nspawn-host' "$PUBLICATION"; then
  echo "FAIL: publication.nota missing node_name"
  exit 1
fi

NODE_PUBLIC_KEY=$(cat "$PUB")
if ! grep -qF "$NODE_PUBLIC_KEY" "$PUBLICATION"; then
  echo "FAIL: publication.nota does not carry the host's ssh.pub"
  exit 1
fi

echo "    key.pem (mode 0600): OK"
echo "    ssh.pub (mode 0644): OK"
echo "    publication.nota (mode 0644): OK"
echo "    publication carries node_name + open_ssh_public_key: OK"
echo ""
echo "=== nspawn deployment test PASSED ==="
