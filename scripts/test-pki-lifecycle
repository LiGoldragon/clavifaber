#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -gt 0 ]; then
  CLAVIFABER=("$@")
else
  CLAVIFABER=(cargo run --quiet --)
fi

TEST_DIRECTORY=$(mktemp -d "/tmp/clavifaber-pki-test.XXXXXX")
GNUPGHOME="$TEST_DIRECTORY/gpg"

cleanup() {
  gpgconf --homedir "$GNUPGHOME" --kill gpg-agent 2>/dev/null || true
  rm -rf "$TEST_DIRECTORY"
}
trap cleanup EXIT

echo "=== PKI lifecycle test (NOTA-only operator surface) ==="
echo "    test directory: $TEST_DIRECTORY"

echo ""
echo "--- Phase 1: Generate test GPG Ed25519 key ---"
mkdir -p "$GNUPGHOME"
chmod 700 "$GNUPGHOME"

KEY_GENERATION_BATCH="$TEST_DIRECTORY/keygen.batch"
cat >"$KEY_GENERATION_BATCH" <<'BATCH'
%no-protection
Key-Type: eddsa
Key-Curve: ed25519
Key-Usage: sign
Name-Real: Aedifico Test CA
Name-Email: test@aedifico.criome
Expire-Date: 0
%commit
BATCH

export GNUPGHOME
gpg --batch --gen-key "$KEY_GENERATION_BATCH" 2>&1 | grep -v "^$"

KEYGRIP=$(gpg --list-secret-keys --with-keygrip --with-colons 2>/dev/null \
  | grep '^grp:' | head -1 | cut -d: -f10)

if [ -z "$KEYGRIP" ]; then
  echo "FAIL: could not extract keygrip"
  exit 1
fi
echo "    keygrip: $KEYGRIP"

gpg-connect-agent /bye 2>/dev/null

echo ""
echo "--- Phase 2: IdentitySetup ---"
NODE_DIRECTORY="$TEST_DIRECTORY/identity-probus"
"${CLAVIFABER[@]}" "(IdentitySetup \"$NODE_DIRECTORY\")" >/dev/null
NODE_SSH_PUBLIC_KEY=$(cat "$NODE_DIRECTORY/ssh.pub")
echo "    node public key: $NODE_SSH_PUBLIC_KEY"

"${CLAVIFABER[@]}" "(OpenSshPublicKeyDerivation \"$NODE_DIRECTORY\")" >/dev/null
DERIVED_PUBLIC_KEY=$(cat "$NODE_DIRECTORY/ssh.pub")
if [ "$DERIVED_PUBLIC_KEY" != "$NODE_SSH_PUBLIC_KEY" ]; then
  echo "FAIL: OpenSshPublicKeyDerivation diverged from IdentitySetup"
  exit 1
fi
echo "    OpenSshPublicKeyDerivation: OK (matches)"

echo ""
echo "--- Phase 3: CertificateAuthorityIssuance ---"
CA_CERTIFICATE="$TEST_DIRECTORY/ca.pem"
"${CLAVIFABER[@]}" "(CertificateAuthorityIssuance $KEYGRIP \"Aedifico Test CA\" \"$CA_CERTIFICATE\")" >/dev/null

if [ ! -s "$CA_CERTIFICATE" ]; then
  echo "FAIL: CA cert not created"
  exit 1
fi
echo "    CA certificate: $(wc -c <"$CA_CERTIFICATE") bytes"

SUBJECT=$(openssl x509 -in "$CA_CERTIFICATE" -noout -subject 2>/dev/null || echo "PARSE_FAIL")
echo "    openssl subject: $SUBJECT"
IS_CA=$(openssl x509 -in "$CA_CERTIFICATE" -noout -text 2>/dev/null | grep -c "CA:TRUE" || true)
if [ "$IS_CA" -lt 1 ]; then
  echo "FAIL: CA cert does not have CA:TRUE"
  exit 1
fi
echo "    CA:TRUE constraint: OK"

# Idempotency on CA: re-issuance is a no-op (file already exists).
CA_BEFORE=$(cat "$CA_CERTIFICATE")
"${CLAVIFABER[@]}" "(CertificateAuthorityIssuance $KEYGRIP \"Aedifico Test CA\" \"$CA_CERTIFICATE\")" >/dev/null
CA_AFTER=$(cat "$CA_CERTIFICATE")
if [ "$CA_BEFORE" != "$CA_AFTER" ]; then
  echo "FAIL: CA cert was re-issued instead of skipped"
  exit 1
fi
echo "    CA idempotency: OK (skip on existing file)"

echo ""
echo "--- Phase 4: ServerCertificateIssuance ---"
SERVER_CERTIFICATE="$TEST_DIRECTORY/server.pem"
SERVER_PRIVATE_KEY="$TEST_DIRECTORY/server.key"
"${CLAVIFABER[@]}" "(ServerCertificateIssuance $KEYGRIP \"$CA_CERTIFICATE\" \"faber.criome\" \"$SERVER_CERTIFICATE\" \"$SERVER_PRIVATE_KEY\")" >/dev/null

if [ ! -s "$SERVER_CERTIFICATE" ] || [ ! -s "$SERVER_PRIVATE_KEY" ]; then
  echo "FAIL: server cert/key not created"
  exit 1
fi
echo "    server certificate: $(wc -c <"$SERVER_CERTIFICATE") bytes"
echo "    server private key: $(wc -c <"$SERVER_PRIVATE_KEY") bytes"

"${CLAVIFABER[@]}" "(CertificateChainVerification \"$CA_CERTIFICATE\" \"$SERVER_CERTIFICATE\")" >/dev/null
echo "    verify chain: OK"

echo ""
echo "--- Phase 5: ClientCertificateIssuance ---"
NODE_CERTIFICATE="$TEST_DIRECTORY/probus.pem"
"${CLAVIFABER[@]}" "(ClientCertificateIssuance $KEYGRIP \"$CA_CERTIFICATE\" \"$NODE_SSH_PUBLIC_KEY\" \"probus@aedifico\" \"$NODE_CERTIFICATE\")" >/dev/null

if [ ! -s "$NODE_CERTIFICATE" ]; then
  echo "FAIL: node cert not created"
  exit 1
fi
echo "    node certificate: $(wc -c <"$NODE_CERTIFICATE") bytes"

"${CLAVIFABER[@]}" "(CertificateChainVerification \"$CA_CERTIFICATE\" \"$NODE_CERTIFICATE\")" >/dev/null
echo "    verify chain: OK"
NODE_SUBJECT=$(openssl x509 -in "$NODE_CERTIFICATE" -noout -subject 2>/dev/null || echo "PARSE_FAIL")
echo "    openssl subject: $NODE_SUBJECT"

echo ""
echo "--- Phase 6: Corruption recovery ---"
CORRUPT_DIRECTORY="$TEST_DIRECTORY/identity-corrupt"
"${CLAVIFABER[@]}" "(IdentitySetup \"$CORRUPT_DIRECTORY\")" >/dev/null
ORIGINAL_PUBLIC_KEY=$(cat "$CORRUPT_DIRECTORY/ssh.pub")

echo "GARBAGE" >"$CORRUPT_DIRECTORY/key.pem"

"${CLAVIFABER[@]}" "(IdentitySetup \"$CORRUPT_DIRECTORY\")" >/dev/null 2>&1
NEW_PUBLIC_KEY=$(cat "$CORRUPT_DIRECTORY/ssh.pub")

if [ "$ORIGINAL_PUBLIC_KEY" = "$NEW_PUBLIC_KEY" ]; then
  echo "FAIL: key not regenerated after corruption"
  exit 1
fi

BROKEN_COUNT=$(find "$CORRUPT_DIRECTORY" -maxdepth 1 -name 'key.pem.broken.*' | wc -l)
if [ "$BROKEN_COUNT" -lt 1 ]; then
  echo "FAIL: broken key not preserved"
  exit 1
fi
echo "    corrupt key preserved: $BROKEN_COUNT broken file(s)"
echo "    new key generated: OK"

echo ""
echo "--- Phase 7: Second client certificate (different node) ---"
SECOND_NODE_DIRECTORY="$TEST_DIRECTORY/identity-faber"
"${CLAVIFABER[@]}" "(IdentitySetup \"$SECOND_NODE_DIRECTORY\")" >/dev/null
SECOND_NODE_SSH_PUBLIC_KEY=$(cat "$SECOND_NODE_DIRECTORY/ssh.pub")

SECOND_NODE_CERTIFICATE="$TEST_DIRECTORY/faber-node.pem"
"${CLAVIFABER[@]}" "(ClientCertificateIssuance $KEYGRIP \"$CA_CERTIFICATE\" \"$SECOND_NODE_SSH_PUBLIC_KEY\" \"faber@aedifico\" \"$SECOND_NODE_CERTIFICATE\")" >/dev/null

"${CLAVIFABER[@]}" "(CertificateChainVerification \"$CA_CERTIFICATE\" \"$SECOND_NODE_CERTIFICATE\")" >/dev/null
echo "    second node cert verified: OK"

echo ""
echo "--- Phase 8: YggdrasilKeypairSetup + PublicKeyPublicationWriting ---"
YGGDRASIL_KEYPAIR="$TEST_DIRECTORY/yggdrasil/keypair.json"
PUBLICATION="$TEST_DIRECTORY/publication.nota"

"${CLAVIFABER[@]}" "(YggdrasilKeypairSetup \"$YGGDRASIL_KEYPAIR\")" >/dev/null

if [ ! -s "$YGGDRASIL_KEYPAIR" ]; then
  echo "FAIL: yggdrasil keypair not created"
  exit 1
fi

YGGDRASIL_KEYPAIR_MODE=$(stat -c %a "$YGGDRASIL_KEYPAIR")
if [ "$YGGDRASIL_KEYPAIR_MODE" != "600" ]; then
  echo "FAIL: yggdrasil keypair mode is $YGGDRASIL_KEYPAIR_MODE, expected 600"
  exit 1
fi
echo "    yggdrasil keypair mode 0600: OK"

# Idempotency: re-running keeps the same keypair.
YGGDRASIL_BEFORE=$(cat "$YGGDRASIL_KEYPAIR")
"${CLAVIFABER[@]}" "(YggdrasilKeypairSetup \"$YGGDRASIL_KEYPAIR\")" >/dev/null
YGGDRASIL_AFTER=$(cat "$YGGDRASIL_KEYPAIR")
if [ "$YGGDRASIL_BEFORE" != "$YGGDRASIL_AFTER" ]; then
  echo "FAIL: yggdrasil keypair rotated under re-run (must stay stable)"
  exit 1
fi
echo "    yggdrasil keypair stable across re-run: OK"

# Publication assembles typed yggdrasil projection + identity ssh.pub.
"${CLAVIFABER[@]}" "(PublicKeyPublicationWriting probus \"$NODE_DIRECTORY\" (YggdrasilKeypairLocation \"$YGGDRASIL_KEYPAIR\") None \"$PUBLICATION\")" >/dev/null

if [ ! -s "$PUBLICATION" ]; then
  echo "FAIL: publication.nota not written"
  exit 1
fi
echo "    publication.nota: $(wc -c <"$PUBLICATION") bytes"

PUBLICATION_MODE=$(stat -c %a "$PUBLICATION")
if [ "$PUBLICATION_MODE" != "644" ]; then
  echo "FAIL: publication.nota mode is $PUBLICATION_MODE, expected 644"
  exit 1
fi
echo "    publication.nota mode 0644: OK"

if ! grep -qE '[0-9a-f]{64}' "$PUBLICATION"; then
  echo "FAIL: publication.nota missing yggdrasil public key (64-hex)"
  cat "$PUBLICATION"
  exit 1
fi
echo "    publication carries yggdrasil hex public key: OK"

if ! grep -q 'YggdrasilProjection' "$PUBLICATION"; then
  echo "FAIL: publication.nota missing typed YggdrasilProjection record"
  cat "$PUBLICATION"
  exit 1
fi
echo "    publication carries typed YggdrasilProjection record: OK"

echo ""
echo "=== ALL TESTS PASSED ==="
