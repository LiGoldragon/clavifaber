#!/usr/bin/env bash
#
# test-deployment-sandbox — exercise clavifaber's deployment shape
# in a rootless sandbox container.
#
# We use **bubblewrap** (`bwrap`), not `systemd-nspawn`, because
# spawning a contained process the script itself owns shouldn't need
# sudo. bwrap uses user namespaces to create the sandbox unprivileged.
# nspawn could do the same in principle (--private-users) but on
# this distro it requires systemd-nsresourced for UID-range
# allocation (not present), so it falls back to needing
# CAP_SYS_ADMIN. bwrap has none of that ceremony.
#
# What the test does:
#   1. Builds the clavifaber binary via nix.
#   2. Generates an SSH host key on the host side (as sshd would on
#      a real CriomOS first boot — clavifaber does NOT own the SSH
#      host key any more; it consumes the one sshd creates).
#   3. Sets up a host-visible state directory that the sandbox
#      will mount at /var/lib/clavifaber.
#   4. Runs clavifaber in a bwrap sandbox with /nix/store bind-ro,
#      the SSH-host-key directory bind-ro, the state directory
#      bind-rw.
#   5. Runs the NOTA-only PublicKeyPublicationWriting sequence (the
#      only step CriomOS's complex-init takes today now that
#      clavifaber doesn't create host keys).
#   6. Verifies the host-visible state has the expected publication.
#
# Requires:
#   - bwrap (bubblewrap) — unprivileged
#   - ssh-keygen (any openssh build)
#   - nix
#
# Usage:
#   nix run .#test-deployment-sandbox
#   # or directly (if cwd is the clavifaber repo root):
#   bash scripts/test-deployment-sandbox

set -euo pipefail

if ! command -v bwrap >/dev/null; then
  echo "FAIL: bwrap (bubblewrap) not on PATH" >&2
  exit 1
fi
if ! command -v nix >/dev/null; then
  echo "FAIL: nix not on PATH" >&2
  exit 1
fi
if ! command -v ssh-keygen >/dev/null; then
  echo "FAIL: ssh-keygen not on PATH" >&2
  exit 1
fi

if [[ "${1:-}" == "" ]]; then
  CLAVIFABER_BIN_PATH=$(nix build --print-out-paths --no-link .# 2>/dev/null)/bin/clavifaber
else
  CLAVIFABER_BIN_PATH="$1"
fi

if [[ ! -x "$CLAVIFABER_BIN_PATH" ]]; then
  echo "FAIL: clavifaber binary not executable at $CLAVIFABER_BIN_PATH" >&2
  exit 1
fi

TEST_ROOT=$(mktemp -d /tmp/clavifaber-deployment-test.XXXXXX)
STATE_DIR="$TEST_ROOT/state"
SSH_DIR="$TEST_ROOT/ssh"
mkdir -p "$STATE_DIR" "$SSH_DIR"
chmod 755 "$STATE_DIR"

# Fabricate the SSH host key that sshd would have produced on a real
# CriomOS first boot. clavifaber will read the .pub file, never the
# private key.
ssh-keygen -t ed25519 -f "$SSH_DIR/ssh_host_ed25519_key" -N "" -C "sandbox-host" -q

cleanup() {
  rm -rf "$TEST_ROOT"
}
trap cleanup EXIT

echo "=== clavifaber deployment test (rootless container) ==="
echo "    state dir:    $STATE_DIR"
echo "    ssh-host dir: $SSH_DIR"
echo "    clavifaber:   $CLAVIFABER_BIN_PATH"

# bwrap arguments:
#   --ro-bind /nix /nix     — clavifaber binary's closure is here, read-only
#   --ro-bind ssh dir       — sshd's ssh_host_ed25519_key.pub
#   --bind state /var/...   — clavifaber writes its state here, host-visible
#   --proc /proc            — fresh /proc for the new pid namespace
#   --dev /dev              — minimal /dev (urandom etc)
#   --tmpfs /tmp /etc       — fresh; sandbox tight
#   --unshare-{pid,uts,ipc,user} — fresh namespaces; no host pollution
BWRAP_ARGS=(
  --ro-bind /nix /nix
  --ro-bind "$SSH_DIR" /etc/ssh
  --bind "$STATE_DIR" /var/lib/clavifaber
  --proc /proc
  --dev /dev
  --tmpfs /tmp
  --tmpfs /etc/clavifaber
  --setenv PATH /nix/store/none-real
  --unshare-pid --unshare-uts --unshare-ipc --unshare-user
  --new-session
  --die-with-parent
  --hostname clavifaber-deployment-test
)

echo ""
echo "--- step 1/1: PublicKeyPublicationWriting ---"
bwrap "${BWRAP_ARGS[@]}" -- \
  "$CLAVIFABER_BIN_PATH" \
  '(PublicKeyPublicationWriting bwrap-host (OpenSshPublicKeyLocation "/etc/ssh/ssh_host_ed25519_key.pub") None None "/var/lib/clavifaber/publication.nota")'

echo ""
echo "--- verifying host-visible outputs ---"

PUBLICATION="$STATE_DIR/publication.nota"
if [ ! -s "$PUBLICATION" ]; then
  echo "FAIL: $PUBLICATION missing or empty"
  exit 1
fi

PUBLICATION_MODE=$(stat -c %a "$PUBLICATION")
if [ "$PUBLICATION_MODE" != "644" ]; then
  echo "FAIL: publication.nota mode $PUBLICATION_MODE (expected 644)"
  exit 1
fi

# Clavifaber must NOT have written a key.pem — it doesn't own host keys.
if [ -e "$STATE_DIR/key.pem" ]; then
  echo "FAIL: clavifaber wrote key.pem; it should not own host keys"
  exit 1
fi

if ! grep -q 'PublicKeyPublication' "$PUBLICATION"; then
  echo "FAIL: publication.nota missing PublicKeyPublication record"
  exit 1
fi
if ! grep -q 'bwrap-host' "$PUBLICATION"; then
  echo "FAIL: publication.nota missing node_name"
  exit 1
fi

SSHD_PUB_KEY=$(cat "$SSH_DIR/ssh_host_ed25519_key.pub")
if ! grep -qF "$SSHD_PUB_KEY" "$PUBLICATION"; then
  echo "FAIL: publication.nota does not carry sshd's ssh.pub verbatim"
  exit 1
fi

echo "    publication.nota (mode 0644): OK"
echo "    no clavifaber-owned key.pem (sshd owns the host key): OK"
echo "    publication carries sshd's ssh.pub verbatim: OK"
echo ""
echo "=== rootless deployment test PASSED ==="
